{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-flash",
  "plugin": [
    "opencode-antigravity-auth@beta"
  ],
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem"
      ],
      "environment": {
        "ALLOWED_DIRECTORIES": "/home/sbonfanti/ai-dev,/home/sbonfanti/Scrivania/Progetti"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "duckduckgo-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ericthered926/duckduckgo-mcp-server"
      ]
    },
    "supabase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest"
      ],
      "environment": {
        "SUPABASE_ACCESS_TOKEN": "$SUPABASE_MCP_TOKEN"
      }
    }
  }
}
